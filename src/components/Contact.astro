---
const { email, linkedin, github } = Astro.props;
---

<section id="contact" class="px-6 md:px-12 py-32 border-t border-border">
  <div class="max-w-5xl mx-auto">

    <div class="fade-up max-w-2xl">
      <span class="font-mono text-xs text-accent tracking-[0.2em] uppercase">contact</span>
      <h2 class="font-display font-bold text-text mt-3 mb-6 leading-tight" style="font-size: clamp(2rem, 5vw, 3.5rem);">
        Let's work<br/>together
      </h2>
      <p class="text-dim font-light text-base mb-12 leading-relaxed max-w-md">
        Open to data engineering internship roles, freelance projects, and interesting conversations. Reach out — I reply fast.
      </p>

      <div class="space-y-3">
        <a href={`mailto:${email}`}
           class="flex items-center gap-4 group py-4 border-b border-border hover:border-muted transition-colors">
          <span class="font-mono text-xs text-dim w-20">email</span>
          <span class="text-text group-hover:text-accent transition-colors">{email}</span>
          <svg class="ml-auto text-muted group-hover:text-accent group-hover:translate-x-1 transition-all" width="14" height="14" viewBox="0 0 16 16" fill="none">
            <path d="M3 13L13 3M13 3H6M13 3V10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
        <a href={linkedin} target="_blank" rel="noopener"
           class="flex items-center gap-4 group py-4 border-b border-border hover:border-muted transition-colors">
          <span class="font-mono text-xs text-dim w-20">linkedin</span>
          <span class="text-text group-hover:text-accent transition-colors">utsab-dangol</span>
          <svg class="ml-auto text-muted group-hover:text-accent group-hover:translate-x-1 transition-all" width="14" height="14" viewBox="0 0 16 16" fill="none">
            <path d="M3 13L13 3M13 3H6M13 3V10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
        <a href={github} target="_blank" rel="noopener"
           class="flex items-center gap-4 group py-4 border-b border-border hover:border-muted transition-colors">
          <span class="font-mono text-xs text-dim w-20">github</span>
          <span class="text-text group-hover:text-accent transition-colors">utsabdangol</span>
          <svg class="ml-auto text-muted group-hover:text-accent group-hover:translate-x-1 transition-all" width="14" height="14" viewBox="0 0 16 16" fill="none">
            <path d="M3 13L13 3M13 3H6M13 3V10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    </div>

  </div>
</section>

<footer class="px-6 md:px-12 py-8 border-t border-border">
  <div class="max-w-5xl mx-auto flex items-center justify-between">
    <span class="font-mono text-xs text-muted">© 2025 Utsab Dangol</span>
    <span class="font-mono text-xs text-muted">Kathmandu, Nepal</span>
  </div>
</footer>
