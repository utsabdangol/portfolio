---
const { projects } = Astro.props;
const featured = projects.filter((p: any) => p.featured);
const rest = projects.filter((p: any) => !p.featured);
---

<section id="projects" class="px-6 md:px-12 py-32 border-t border-border">
  <div class="max-w-5xl mx-auto">

    <div class="fade-up flex items-end justify-between mb-16">
      <div>
        <span class="font-mono text-xs text-accent tracking-[0.2em] uppercase">projects</span>
        <h2 class="font-display font-semibold text-3xl text-text mt-2">Selected work</h2>
      </div>
      <a href="https://github.com/utsabdangol" target="_blank" rel="noopener"
         class="font-mono text-xs text-dim hover:text-accent transition-colors">
        github →
      </a>
    </div>

    <!-- Featured projects -->
    <div class="space-y-4 mb-4">
      {featured.map((project: any, i: number) => (
        <a href={project.url} target="_blank" rel="noopener"
           class="fade-up group flex flex-col md:flex-row md:items-center gap-4 md:gap-8 p-6 rounded-xl border border-border hover:border-muted bg-surface/40 hover:bg-surface transition-all duration-300 block"
           style={`transition-delay: ${i * 80}ms`}>
          <div class="flex-1">
            <div class="flex items-center gap-3 mb-2">
              <h3 class="font-display font-semibold text-text text-lg group-hover:text-accent transition-colors">{project.title}</h3>
              <span class="font-mono text-xs text-muted border border-border px-2 py-0.5 rounded-full">featured</span>
            </div>
            <p class="text-dim text-sm font-light leading-relaxed max-w-xl">{project.description}</p>
          </div>
          <div class="flex flex-wrap gap-2 md:justify-end md:max-w-xs">
            {project.tags.map((tag: string) => (
              <span class="font-mono text-xs text-muted px-2.5 py-1 rounded-full border border-border">{tag}</span>
            ))}
          </div>
          <svg class="shrink-0 text-muted group-hover:text-accent group-hover:translate-x-1 group-hover:-translate-y-1 transition-all" width="16" height="16" viewBox="0 0 16 16" fill="none">
            <path d="M3 13L13 3M13 3H6M13 3V10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      ))}
    </div>

    <!-- Other projects -->
    {rest.length > 0 && (
      <div class="grid md:grid-cols-2 gap-4 mt-4">
        {rest.map((project: any) => (
          <a href={project.url} target="_blank" rel="noopener"
             class="fade-up group p-5 rounded-xl border border-border hover:border-muted bg-surface/20 hover:bg-surface transition-all duration-300 block">
            <div class="flex items-start justify-between mb-3">
              <h3 class="font-display font-medium text-text group-hover:text-accent transition-colors">{project.title}</h3>
              <svg class="shrink-0 text-muted group-hover:text-accent mt-0.5 transition-colors" width="14" height="14" viewBox="0 0 16 16" fill="none">
                <path d="M3 13L13 3M13 3H6M13 3V10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <p class="text-dim text-sm font-light leading-relaxed mb-4">{project.description}</p>
            <div class="flex flex-wrap gap-2">
              {project.tags.map((tag: string) => (
                <span class="font-mono text-xs text-muted">{tag}</span>
              ))}
            </div>
          </a>
        ))}
      </div>
    )}

  </div>
</section>
