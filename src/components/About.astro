---
const { bio } = Astro.props;
---

<section id="about" class="px-6 md:px-12 py-32 max-w-5xl mx-auto">
  <div class="fade-up grid md:grid-cols-[1fr_2fr] gap-16 items-start">

    <!-- Label -->
    <div>
      <span class="font-mono text-xs text-accent tracking-[0.2em] uppercase">about</span>
      <div class="mt-4 w-8 h-px bg-border"></div>
    </div>

    <!-- Content -->
    <div>
      <p class="text-text/80 text-lg font-light leading-relaxed mb-8">{bio}</p>

      <div class="grid grid-cols-2 gap-6 pt-8 border-t border-border">
        <div>
          <p class="font-mono text-xs text-dim uppercase tracking-widest mb-1">Education</p>
          <p class="text-text text-sm">BCA — Prime College</p>
          <p class="text-dim text-sm font-mono">2023 – Present</p>
        </div>
        <div>
          <p class="font-mono text-xs text-dim uppercase tracking-widest mb-1">Based in</p>
          <p class="text-text text-sm">Kathmandu, Nepal</p>
          <p class="text-dim text-sm font-mono">UTC+5:45</p>
        </div>
        <div>
          <p class="font-mono text-xs text-dim uppercase tracking-widest mb-1">Certifications</p>
          <p class="text-text text-sm">AWS Cloud Practitioner</p>
          <p class="text-dim text-sm">ML with Python</p>
        </div>
        <div>
          <p class="font-mono text-xs text-dim uppercase tracking-widest mb-1">Interests</p>
          <p class="text-text text-sm">Data pipelines, MLOps</p>
          <p class="text-dim text-sm">Open source, data systems</p>
        </div>
      </div>
    </div>

  </div>
</section>
