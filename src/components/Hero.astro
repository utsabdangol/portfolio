---
const { shortBio } = Astro.props;
---

<section id="hero" class="min-h-screen flex flex-col justify-end px-6 md:px-12 pb-20 pt-32 relative overflow-hidden">

  <!-- Background grid lines -->
  <div class="absolute inset-0 opacity-[0.03]" style="
    background-image: linear-gradient(#e8e8e8 1px, transparent 1px), linear-gradient(90deg, #e8e8e8 1px, transparent 1px);
    background-size: 60px 60px;
  "></div>

  <!-- Accent glow -->
  <div class="absolute top-1/3 left-1/4 w-96 h-96 rounded-full opacity-[0.04]" style="background: radial-gradient(circle, #e8ff6b 0%, transparent 70%); filter: blur(60px);"></div>

  <div class="relative max-w-5xl">

    <!-- Status pill -->
    <div class="inline-flex items-center gap-2 mb-10 px-3 py-1.5 rounded-full border border-border font-mono text-xs text-dim">
      <span class="w-1.5 h-1.5 rounded-full bg-accent animate-pulse"></span>
      available for internships
    </div>

    <!-- Main heading -->
    <h1 class="font-display font-bold leading-[0.9] tracking-tight text-text mb-8" style="font-size: clamp(3.5rem, 10vw, 8rem);">
      Utsab<br/>
      <span style="color: #e8ff6b;">Dangol</span>
    </h1>

    <!-- Role line -->
    <p class="font-mono text-sm text-dim mb-6 tracking-wide">
      data engineering · machine learning · kathmandu, np
    </p>

    <!-- Short bio -->
    <p class="text-text/60 max-w-lg text-base font-light leading-relaxed mb-12">
      {shortBio}
    </p>

    <!-- CTAs -->
    <div class="flex gap-4 flex-wrap">
      <a href="#projects"
         class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full bg-accent text-bg font-mono text-sm font-medium hover:bg-accent/90 transition-colors">
        view work
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
      <a href="#contact"
         class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full border border-border text-dim font-mono text-sm hover:border-muted hover:text-text transition-colors">
        get in touch
      </a>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 right-12 font-mono text-xs text-muted flex items-center gap-2 rotate-90 origin-right opacity-40">
    scroll
    <div class="w-8 h-px bg-muted"></div>
  </div>

</section>
